NODE_ENV=development
PORT=3000

# Use local PostgreSQL for development
# For GCP Cloud Run, this comes from Secret Manager
DATABASE_URL=postgresql://user:password@localhost:5432/fitness_tracker

# Get this from @BotFather — the OLD token was compromised and must not be reused
TELEGRAM_BOT_TOKEN=your_new_bot_token_here

# Auto-generated during deployment; used for webhook path validation
TELEGRAM_WEBHOOK_SECRET=change_me

# GCP Cloud Run service URL
APP_BASE_URL=https://fitness-tracker-bot-807329620690.us-central1.run.app

# Always webhook on Cloud Run; polling only works for local dev
BOT_MODE=webhook

DEFAULT_TIMEZONE=Asia/Bangkok
LOG_LEVEL=info

# Optional: prefix test messages so your real group knows it's a dev instance
BOT_TEST_MESSAGE_PREFIX=
